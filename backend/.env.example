# ═══════════════════════════════════════════════════════════════
# TalentIQ AI — Environment Configuration
# Copy this file to .env and fill in your values.
# OS environment variables always override .env values.
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_NAME=TalentIQ AI
APP_VERSION=2.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────
# SQLite (default — works with no setup)
DATABASE_URL=sqlite:///./talentiq.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/talentiq

# ── Feature Flags ─────────────────────────────────────────────
# Set to true/false — pydantic parses both correctly
ENABLE_GEMINI=true
ENABLE_BIGQUERY=false
ENABLE_GPU_ACCELERATION=false
ENABLE_MULTI_AGENT=true
ENABLE_ANALYTICS=true
ENABLE_REPORTS=true
ENABLE_EXECUTIVE_REPORTS=true
ENABLE_AI_COPILOT=true
ENABLE_STRATEGY_SIMULATOR=true
ENABLE_BENCHMARKS=true
ENABLE_RATE_LIMITING=false
ENABLE_EVALUATION=true

# ── Google Gemini ─────────────────────────────────────────────
# Get your key: https://aistudio.google.com/apikey
# To enable: set ENABLE_GEMINI=true AND paste your key below
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=2

# ── Google BigQuery ───────────────────────────────────────────
# To enable: set ENABLE_BIGQUERY=true, fill project + credentials
GOOGLE_CLOUD_PROJECT=
BIGQUERY_DATASET=talentiq
# Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# ── AI / ML ───────────────────────────────────────────────────
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
EMBEDDING_BATCH_SIZE=64
TFIDF_MAX_FEATURES=5000
TOP_K_CANDIDATES=200

# ── Security ──────────────────────────────────────────────────
# Change this to a random string in production!
SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────
# Add your frontend URL here for production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
